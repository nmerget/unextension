{
  "name": "@unextension/bridge",
  "version": "0.1.0",
  "description": "Runtime bridge API for unextension plugins",
  "author": "Nicolas Merget",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nmerget/unextension.git",
    "directory": "packages/bridge"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./script": {
      "types": "./dist/script.d.ts",
      "import": "./dist/script.js",
      "require": "./dist/script.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "25.7.0",
    "@vitest/browser": "4.1.6",
    "jsdom": "29.1.1",
    "typescript": "6.0.3"
  }
}
