{
  "name": "@unextension/showcase",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync": "node ../cli/dist/cli.js sync",
    "build": "pnpm --filter @unextension/cli build && pnpm --filter @unextension/bridge build && vite build && node scripts/build.mjs && node ../cli/dist/cli.js sync",
    "build:jetbrains": "node ../cli/dist/cli.js build jetbrains",
    "build:vscode": "node ../cli/dist/cli.js build vscode",
    "dev:jetbrains": "node ../cli/dist/cli.js dev jetbrains",
    "dev:vscode": "node ../cli/dist/cli.js dev vscode"
  },
  "dependencies": {
    "@unextension/bridge": "workspace:*",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.15.0"
  },
  "devDependencies": {
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@unextension/cli": "workspace:*",
    "@vitejs/plugin-react": "6.0.1",
    "esbuild": "0.28.0",
    "typescript": "6.0.3",
    "vite": "8.0.12",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
